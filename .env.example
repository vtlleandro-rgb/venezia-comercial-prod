# ============================================================
# VENEZIA COMERCIAL — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env com valores reais.
# ============================================================

# ----- BANCO DE DADOS -----
# MySQL compatível (Railway, PlanetScale, TiDB, local)
# Formato: mysql://user:password@host:port/database
DATABASE_URL=mysql://user:password@localhost:3306/venezia_comercial

# ----- AUTENTICAÇÃO -----
# Chave secreta para assinar os JWTs de sessão (mínimo 32 chars)
JWT_SECRET=gere_um_secret_seguro_aqui_minimo_32_caracteres

# OpenID do proprietário/admin (quem faz login primeiro vira admin)
OWNER_OPEN_ID=

# ----- OAUTH (opcional — necessário apenas para login de corretores) -----
# Se não configurado, o sistema de senha local (venezia2025) ainda funciona
# para o Dashboard interno. Configure para habilitar login de corretores.
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=
VITE_APP_ID=

# ----- TÍTULOS E IDENTIDADE -----
VITE_APP_TITLE=Residencial Venezia — Central Comercial

# ----- PDF (geração server-side via Puppeteer) -----
# Path do Chromium instalado no servidor
# macOS: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Linux: /usr/bin/chromium ou /usr/bin/chromium-browser
CHROMIUM_PATH=/usr/bin/chromium

# ----- ANALYTICS (opcional) -----
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
